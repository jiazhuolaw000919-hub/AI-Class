{
  "version": 2,
  "rewrites": [
    {
      "source": "/pages/academy.html",
      "destination": "/pages/academy.html"
    },
    {
      "source": "/pages/lesson.html",
      "destination": "/pages/lesson.html"
    },
    {
      "source": "/pages/(.*)",
      "destination": "/pages/$1"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ]
}
