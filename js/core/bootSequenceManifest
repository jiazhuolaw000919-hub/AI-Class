export function getBootPhases() {
  return JSON.parse(JSON.stringify(BOOT_PHASES));
}

export function getPhaseById(id) {
  return BOOT_PHASES.find(p => p.id === id) || null;
}

export function getPhaseByOrder(order) {
  return BOOT_PHASES.find(p => p.order === order) || null;
}

export function getActivePhases() {
  return BOOT_PHASES.filter(p => p.status === 'active');
}

export function getPhaseCount() {
  return BOOT_PHASES.length;
}

// Global mount
if (typeof window !== 'undefined') {
  window.bootSequenceManifest = {
    BOOT_PHASES,
    getBootPhases,
    getPhaseById,
    getPhaseByOrder,
    getActivePhases,
    getPhaseCount,
    init: function() { console.log('✅ BootSequenceManifest ready'); return this; }
  };
  
  if (typeof LawAIApp !== 'undefined' && LawAIApp) {
    LawAIApp.BootSequenceManifest = window.bootSequenceManifest;
